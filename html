<script>
// ============================================================
//  SCHEMATIC CANVAS BACKGROUND
// ============================================================
const canvas = document.getElementById('bg-canvas');
const ctx = canvas.getContext('2d');
let W, H, T = 0;

function resize() {
  W = canvas.width = window.innerWidth;
  H = canvas.height = window.innerHeight;
}
resize();
window.addEventListener('resize', resize);

// ---- TUNNEL ----
function tunnel(t) {
  const cx = W * 0.52, cy = H * 0.50;
  const steps = 24;
  for (let i = 0; i < steps; i++) {
    const f = i / steps;
    const breathe = Math.sin(t * 0.35 + f * 2.5) * 0.012;
    const rw = (W * 0.52) * (f + breathe);
    const rh = (H * 0.50) * (f + breathe);
    const a = f * 0.22 + 0.01;
    ctx.strokeStyle = `rgba(216,212,200,${a})`;
    ctx.lineWidth = 0.35;
    ctx.strokeRect(cx - rw, cy - rh, rw * 2, rh * 2);
  }
}

// ---- VERTICAL CENTER LINE + MOVING DOTS ----
function vertLine(t) {
  const x = W * 0.52;
  ctx.strokeStyle = 'rgba(216,212,200,0.1)';
  ctx.lineWidth = 0.6;
  ctx.beginPath(); ctx.moveTo(x, 0); ctx.lineTo(x, H); ctx.stroke();

  // two dots travelling at different speeds
  [[0.0, 0.13], [0.55, 0.20]].forEach(([phase, spd]) => {
    const y = ((T * spd + phase) % 1.3 - 0.15) * H;
    if (y < 0 || y > H) return;
    const edge = 1 - Math.abs(y / H - 0.5) * 2.2;
    const a = Math.max(0, edge);
    // glow
    const g = ctx.createRadialGradient(x, y, 0, x, y, 8);
    g.addColorStop(0, `rgba(184,168,120,${a * 0.5})`);
    g.addColorStop(1, 'rgba(184,168,120,0)');
    ctx.fillStyle = g;
    ctx.beginPath(); ctx.arc(x, y, 8, 0, Math.PI*2); ctx.fill();
    // core dot
    ctx.fillStyle = `rgba(216,212,200,${a * 0.9})`;
    ctx.beginPath(); ctx.arc(x, y, 2, 0, Math.PI*2); ctx.fill();
  });
}

// ---- CROSSHAIR ----
function crosshair(x, y, r, t, phase) {
  const p = 0.5 + 0.5 * Math.sin(t * 1.1 + phase);
  const a = 0.15 + 0.25 * p;
  const arm = r * 3;
  ctx.strokeStyle = `rgba(216,212,200,${a})`;
  ctx.lineWidth = 0.5;
  ctx.beginPath();
  ctx.arc(x, y, r, 0, Math.PI*2); ctx.stroke();
  ctx.beginPath();
  ctx.moveTo(x - arm, y); ctx.lineTo(x - r*1.2, y);
  ctx.moveTo(x + r*1.2, y); ctx.lineTo(x + arm, y);
  ctx.moveTo(x, y - arm); ctx.lineTo(x, y - r*1.2);
  ctx.moveTo(x, y + r*1.2); ctx.lineTo(x, y + arm);
  ctx.stroke();
  // pulse dot
  ctx.fillStyle = `rgba(216,212,200,${a * 1.4})`;
  ctx.beginPath(); ctx.arc(x, y, 1.5, 0, Math.PI*2); ctx.fill();
}

// ---- BRACKET CORNER ----
function bracket(x, y, sz, flip, t, phase) {
  const a = 0.12 + 0.08 * Math.sin(t * 0.6 + phase);
  const sx = flip.x ? -1 : 1, sy = flip.y ? -1 : 1;
  ctx.strokeStyle = `rgba(216,212,200,${a})`;
  ctx.lineWidth = 0.7;
  ctx.beginPath();
  ctx.moveTo(x + sx*sz, y); ctx.lineTo(x, y); ctx.lineTo(x, y + sy*sz);
  ctx.stroke();
  ctx.fillStyle = `rgba(216,212,200,${a})`;
  ctx.fillRect(x-1.5, y-1.5, 3, 3);
}

// ---- X BOX ----
function xBox(x, y, sz, a) {
  ctx.strokeStyle = `rgba(216,212,200,${a})`;
  ctx.lineWidth = 0.6;
  ctx.strokeRect(x-sz, y-sz, sz*2, sz*2);
  ctx.beginPath();
  ctx.moveTo(x-sz, y-sz); ctx.lineTo(x+sz, y+sz);
  ctx.moveTo(x+sz, y-sz); ctx.lineTo(x-sz, y+sz);
  ctx.stroke();
}

// ---- DASHED LINE ----
function dashedLine(x1,y1,x2,y2,a,t,spd) {
  ctx.setLineDash([4, 7]);
  ctx.lineDashOffset = -(T * spd) % 22;
  ctx.strokeStyle = `rgba(216,212,200,${a})`;
  ctx.lineWidth = 0.5;
  ctx.beginPath(); ctx.moveTo(x1,y1); ctx.lineTo(x2,y2); ctx.stroke();
  ctx.setLineDash([]);
}

// ---- GRID LINES ----
function gridLines() {
  [[0.24,0.035],[0.52,0.025],[0.75,0.03]].forEach(([f,a]) => {
    const y = f * H + Math.sin(T*0.12 + f*4)*0.4;
    ctx.strokeStyle = `rgba(216,212,200,${a})`;
    ctx.lineWidth = 0.5;
    ctx.beginPath(); ctx.moveTo(0,y); ctx.lineTo(W,y); ctx.stroke();
  });
  [[0.12,0.025],[0.38,0.02],[0.62,0.02],[0.86,0.025]].forEach(([f,a]) => {
    const x = f * W;
    ctx.strokeStyle = `rgba(216,212,200,${a})`;
    ctx.lineWidth = 0.5;
    ctx.beginPath(); ctx.moveTo(x,0); ctx.lineTo(x,H); ctx.stroke();
  });
}

// ---- HAZARD STRIPE ----
function hazard(x, y, w, h, a, t) {
  const sw = 9, off = (T * 18) % (sw * 2);
  ctx.save();
  ctx.beginPath(); ctx.rect(x,y,w,h); ctx.clip();
  ctx.strokeStyle = `rgba(216,212,200,${a})`;
  ctx.lineWidth = 0.6;
  for (let i = -h; i < w+h; i += sw*2) {
    ctx.beginPath();
    ctx.moveTo(x+i-off, y); ctx.lineTo(x+i+h-off, y+h);
    ctx.stroke();
  }
  ctx.restore();
}

// ---- BLINKING RECT CLUSTER ----
function rectCluster(x, y, t, ph) {
  [4,8,5,3,9,6].forEach((s, i) => {
    if (Math.sin(T*0.7 + ph + i*0.8) < 0.2) return;
    ctx.strokeStyle = `rgba(216,212,200,0.14)`;
    ctx.lineWidth = 0.5;
    ctx.strokeRect(x + i*13, y, s, s);
  });
}

// ---- DATA BARS ----
function dataBars(x, y, t, ph) {
  for (let i = 0; i < 7; i++) {
    const w = 4 + 22 * (0.5 + 0.5*Math.sin(T*0.45 + ph + i*0.75));
    ctx.fillStyle = `rgba(216,212,200,0.10)`;
    ctx.fillRect(x, y + i*5, w, 2);
  }
}

// ---- SCAN BEAM ----
function scanBeam() {
  const y = ((T * 0.055) % 1.2 - 0.1) * H;
  const g = ctx.createLinearGradient(0,y-4,0,y+4);
  g.addColorStop(0,'rgba(184,168,120,0)');
  g.addColorStop(0.5,'rgba(184,168,120,0.035)');
  g.addColorStop(1,'rgba(184,168,120,0)');
  ctx.fillStyle = g;
  ctx.fillRect(0, y-4, W, 8);
}

// ---- LABEL ----
function lbl(x,y,txt,a) {
  ctx.font = '6px "Share Tech Mono",monospace';
  ctx.fillStyle = `rgba(216,212,200,${a})`;
  ctx.fillText(txt, x, y);
}

// ============================================================
function draw() {
  ctx.clearRect(0, 0, W, H);
  T += 0.007;

  scanBeam();
  gridLines();
  tunnel(T);
  vertLine(T);

  // crosshairs
  crosshair(W*.52, H*.07, 4, T, 0.0);
  crosshair(W*.52, H*.74, 4, T, 1.5);
  crosshair(W*.52, H*.90, 3, T, 2.4);
  crosshair(W*.14, H*.44, 3, T, 0.9);
  crosshair(W*.85, H*.36, 3, T, 2.0);
  crosshair(W*.83, H*.64, 3, T, 3.2);
  crosshair(W*.27, H*.20, 2.5, T, 1.1);

  // corner brackets
  bracket(W*.07, H*.11, 18, {x:0,y:0}, T, 0.0);
  bracket(W*.73, H*.14, 22, {x:1,y:0}, T, 1.3);
  bracket(W*.09, H*.87, 16, {x:0,y:1}, T, 2.1);
  bracket(W*.89, H*.84, 20, {x:1,y:1}, T, 0.7);
  bracket(W*.33, H*.23, 11, {x:0,y:0}, T, 1.8);
  bracket(W*.66, H*.76, 11, {x:1,y:1}, T, 2.9);

  // X boxes
  xBox(W*.07, H*.11, 10, 0.14);
  xBox(W*.73, H*.14, 10, 0.12);
  xBox(W*.89, H*.84, 10, 0.11);

  // dashed connectors
  dashedLine(W*.52, H*.07, W*.73, H*.14, 0.07, T, 7);
  dashedLine(W*.14, H*.44, W*.22, H*.52, 0.06, T, 9);
  dashedLine(W*.85, H*.36, W*.89, H*.52, 0.05, T, 11);
  dashedLine(W*.33, H*.23, W*.52, H*.07, 0.05, T, 8);

  // rect clusters (top right — barcode-like)
  rectCluster(W*.63, H*.10, T, 0.0);
  rectCluster(W*.63, H*.14, T, 1.1);
  rectCluster(W*.85, H*.56, T, 2.3);

  // data bars (right margin)
  dataBars(W*.935, H*.33, T, 0.0);
  dataBars(W*.935, H*.60, T, 1.8);

  // hazard stripe — bottom left
  hazard(W*.02, H*.87, W*.11, H*.055, 0.09, T);

  // labels
  const la = 0.07 + 0.03 * Math.sin(T*0.6);
  lbl(W*.63, H*.09, '|| || ||| | || |||', la);
  lbl(W*.63, H*.125, '||| || | ||| ||', la*.8);
  lbl(W*.63, H*.16, '|| | |||| || |', la*.6);
  lbl(W*.02, H*.29, '+ + +', la);
  lbl(W*.935, H*.27, '▪ ▪ ▪ ▪ ▪', la);
  lbl(W*.935, H*.30, '▪ ▪ ▪', la*.7);
  lbl(W*.02, H*.97, 'SYS_001  34.0590N  118.2321W', 0.16);
  ctx.font = 'italic 7px "Courier Prime",monospace';
  ctx.fillStyle = `rgba(184,168,120,0.14)`;
  ctx.fillText('8Y8.4IK', W*.83, H*.93);

  requestAnimationFrame(draw);
}
draw();

// ---- MILITARY TIME CLOCK ----
function milClock() {
  const now = new Date();
  const h = String(now.getHours()).padStart(2,'0');
  const m = String(now.getMinutes()).padStart(2,'0');
  const s = String(now.getSeconds()).padStart(2,'0');
  document.getElementById('mil-time').textContent = h+':'+m+':'+s;
}
milClock();
setInterval(milClock, 1000);

// ============================================================
// CURSOR
// ============================================================
const cur = document.getElementById('cur');
const curDot = document.getElementById('cur-dot');
let mx=0,my=0,cx=0,cy=0;
document.addEventListener('mousemove', e => {
  mx=e.clientX; my=e.clientY;
  curDot.style.left=mx+'px'; curDot.style.top=my+'px';
});
document.querySelectorAll('a,button,.vc,.ac').forEach(el => {
  el.addEventListener('mouseenter',()=>cur.classList.add('big'));
  el.addEventListener('mouseleave',()=>cur.classList.remove('big'));
});
(function animCur(){
  cx+=(mx-cx)*.1; cy+=(my-cy)*.1;
  cur.style.left=cx+'px'; cur.style.top=cy+'px';
  requestAnimationFrame(animCur);
})();

// ============================================================
// PROGRESS + GSAP
// ============================================================
const scenes = document.querySelectorAll('.scene');
const pgs = document.querySelectorAll('.pg');
function goTo(i){ scenes[i].scrollIntoView({behavior:'smooth'}); }
const obs = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if(e.isIntersecting){
      const i = Array.from(scenes).indexOf(e.target);
      pgs.forEach((p,j) => p.classList.toggle('active', j===i));
    }
  });
},{threshold:.5});
scenes.forEach(s => obs.observe(s));

gsap.registerPlugin(ScrollTrigger);
gsap.to('.s1-sys',{opacity:1,duration:.7,delay:.3});
gsap.to('.s1-title',{opacity:1,duration:.5,delay:.1});
gsap.to('.s1-sub',{opacity:1,duration:.6,delay:.6});
gsap.to('.s1-status',{opacity:1,duration:.6,delay:.9});
gsap.to('.s1-scroll',{opacity:1,duration:.6,delay:1.4});
ScrollTrigger.create({trigger:'#s2',start:'top 80%',onEnter:()=>{
  gsap.to('#s2 .sec-eyebrow',{opacity:1,duration:.5});
  gsap.to('#s2 .sec-h',{opacity:1,duration:.6,delay:.15});
  gsap.to('.tx-row',{opacity:1,x:0,duration:.5,stagger:.12,delay:.3});
}});
ScrollTrigger.create({trigger:'#s3',start:'top 80%',onEnter:()=>{
  gsap.to('.vis-scene-label',{opacity:1,duration:.6,delay:.2});
  gsap.to('.vc-art',{opacity:1,scale:1,duration:.8,stagger:.1,delay:.1});
}});
ScrollTrigger.create({trigger:'#s4',start:'top 80%',onEnter:()=>{
  gsap.to('#s4 .sec-eyebrow',{opacity:1,duration:.5});
  gsap.to('#s4 .sec-h',{opacity:1,duration:.6,delay:.15});
  gsap.to('.ac',{opacity:1,y:0,duration:.6,stagger:.15,delay:.3});
}});
ScrollTrigger.create({trigger:'#s5',start:'top 80%',onEnter:()=>{
  gsap.to('#s5 .sec-eyebrow',{opacity:1,duration:.5});
  gsap.to('#s5 .sec-h',{opacity:1,duration:.6,delay:.1});
  gsap.to('.mf p',{opacity:1,y:0,duration:.6,stagger:.18,delay:.3});
  gsap.to('.sb',{opacity:1,x:0,duration:.6,stagger:.12,delay:.4});
}});
ScrollTrigger.create({trigger:'#s6',start:'top 80%',onEnter:()=>{
  gsap.to('.ab',{opacity:1,y:0,duration:.7,stagger:.2,delay:.1});
}});
setInterval(()=>{
  if(Math.random()<.12){
    const tt=document.querySelector('.s1-title');
    gsap.to(tt,{x:(Math.random()-.5)*8,duration:.05,yoyo:true,repeat:3,ease:'none'});
  }
},2500);
</script>
